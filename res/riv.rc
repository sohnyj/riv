// Icon id 1 is shared with the window class. Version info and the manifest
// are appended by the build script.
1 ICON "riv.ico"

#include "resource.h"

IDD_OPTIONS DIALOGEX 0, 0, 320, 252
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
FONT 9, "Segoe UI"
BEGIN
    CONTROL "", IDC_OPTIONS_TAB, "SysTabControl32", WS_TABSTOP, 7, 7, 306, 218
    PUSHBUTTON "Restore Defaults", IDC_RESTORE_DEFAULTS, 7, 231, 70, 14
    DEFPUSHBUTTON "OK", 1, 155, 231, 50, 14
    PUSHBUTTON "Cancel", 2, 209, 231, 50, 14
    PUSHBUTTON "Apply", IDC_APPLY, 263, 231, 50, 14
END

IDD_PAGE_WINDOW DIALOGEX 0, 0, 292, 196
STYLE DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI"
BEGIN
    AUTOCHECKBOX "Background color:", IDC_WINDOW_BGCOLOR_ENABLED, 12, 12, 80, 10
    CONTROL "", IDC_WINDOW_BGCOLOR_BUTTON, "Button", BS_OWNERDRAW | WS_TABSTOP, 108, 10, 50, 14
    LTEXT "Titlebar text:", -1, 12, 34, 80, 8
    AUTORADIOBUTTON "Basic", IDC_WINDOW_TITLEBAR_BASIC, 108, 33, 80, 10, WS_GROUP
    AUTORADIOBUTTON "Minimal", IDC_WINDOW_TITLEBAR_MINIMAL, 108, 46, 80, 10
    AUTORADIOBUTTON "Practical", IDC_WINDOW_TITLEBAR_PRACTICAL, 108, 59, 80, 10
    LTEXT "Fit image to:", -1, 12, 80, 80, 8
    COMBOBOX IDC_WINDOW_FITMODE, 108, 77, 80, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP | WS_GROUP
    AUTOCHECKBOX "Remember window size and position", IDC_WINDOW_SAVE_POSITION, 12, 102, 260, 10
    AUTOCHECKBOX "Ctrl + drag to move window", IDC_WINDOW_CTRL_DRAG, 12, 116, 260, 10
END

IDD_PAGE_IMAGE DIALOGEX 0, 0, 292, 196
STYLE DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Scaling:", -1, 12, 14, 80, 8
    COMBOBOX IDC_IMAGE_FILTERING, 108, 11, 90, 70, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Dither:", -1, 12, 36, 80, 8
    COMBOBOX IDC_IMAGE_DITHER, 108, 33, 90, 70, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Zoom amount:", -1, 12, 58, 80, 8
    EDITTEXT IDC_IMAGE_SCALEFACTOR_EDIT, 108, 55, 40, 13, ES_NUMBER | ES_AUTOHSCROLL
    CONTROL "", IDC_IMAGE_SCALEFACTOR_SPIN, "msctls_updown32", UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_AUTOBUDDY | UDS_ARROWKEYS | UDS_NOTHOUSANDS, 0, 0, 11, 13
    LTEXT "%", -1, 152, 58, 12, 8
    AUTOCHECKBOX "Zoom towards cursor", IDC_IMAGE_CURSOR_ZOOM, 12, 78, 260, 10
    AUTOCHECKBOX "Fractional zooming", IDC_IMAGE_FRACTIONAL_ZOOM, 12, 92, 260, 10
END

IDD_PAGE_MISC DIALOGEX 0, 0, 292, 196
STYLE DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Sort files by:", -1, 12, 14, 80, 8
    COMBOBOX IDC_MISC_SORT, 108, 11, 90, 90, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTORADIOBUTTON "Ascending", IDC_MISC_ASCENDING, 108, 30, 60, 10, WS_GROUP
    AUTORADIOBUTTON "Descending", IDC_MISC_DESCENDING, 172, 30, 60, 10
    LTEXT "Preloading:", -1, 12, 48, 80, 8
    COMBOBOX IDC_MISC_PRELOADING, 108, 45, 90, 70, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP | WS_GROUP
    AUTOCHECKBOX "Loop through folders", IDC_MISC_LOOP_FOLDERS, 12, 64, 260, 10
    LTEXT "Slideshow direction:", -1, 12, 82, 80, 8
    COMBOBOX IDC_MISC_SLIDESHOW_DIRECTION, 108, 79, 90, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Slideshow timer:", -1, 12, 100, 80, 8
    EDITTEXT IDC_MISC_SLIDESHOW_TIMER_EDIT, 108, 97, 40, 13, ES_NUMBER | ES_AUTOHSCROLL
    CONTROL "", IDC_MISC_SLIDESHOW_TIMER_SPIN, "msctls_updown32", UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_AUTOBUDDY | UDS_ARROWKEYS | UDS_NOTHOUSANDS, 0, 0, 11, 13
    LTEXT "sec", -1, 152, 100, 16, 8
    LTEXT "After deletion:", -1, 12, 118, 80, 8
    COMBOBOX IDC_MISC_AFTER_DELETE, 108, 115, 90, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX "Ask before deleting files", IDC_MISC_ASK_DELETE, 12, 134, 260, 10
    AUTOCHECKBOX "Allow MIME content detection", IDC_MISC_MIME_DETECTION, 12, 148, 260, 10
    AUTOCHECKBOX "Save recent files", IDC_MISC_SAVE_RECENTS, 12, 162, 260, 10
    AUTOCHECKBOX "Skip hidden files", IDC_MISC_SKIP_HIDDEN, 12, 176, 260, 10
END

IDD_PAGE_SHORTCUTS DIALOGEX 0, 0, 292, 196
STYLE DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI"
BEGIN
    PUSHBUTTON "Reset to Default", IDC_SHORTCUTS_RESET, 7, 7, 70, 14
    PUSHBUTTON "Clear All", IDC_SHORTCUTS_CLEAR_ALL, 235, 7, 50, 14
    CONTROL "", IDC_SHORTCUTS_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | LVS_NOSORTHEADER | WS_BORDER | WS_TABSTOP, 7, 26, 278, 163
END

IDD_PAGE_ASSOCIATION DIALOGEX 0, 0, 292, 196
STYLE DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI"
BEGIN
    PUSHBUTTON "Select All", IDC_ASSOC_SELECT_ALL, 7, 7, 60, 14
    PUSHBUTTON "Select None", IDC_ASSOC_SELECT_NONE, 225, 7, 60, 14
    CONTROL "", IDC_ASSOC_TREE, "SysTreeView32", TVS_HASBUTTONS | TVS_LINESATROOT | TVS_DISABLEDRAGDROP | TVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 7, 26, 278, 163
END

IDD_CAPTURE_KEYBOARD DIALOGEX 0, 0, 220, 120
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Modify Shortcuts"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Press a key combination to add it:", -1, 7, 9, 200, 8
    CONTROL "", IDC_CAPTURE_KEY_FIELD, "RivKeyCapture", WS_TABSTOP | WS_BORDER, 7, 20, 206, 14
    LISTBOX IDC_CAPTURE_KEY_LIST, 7, 40, 206, 54, LBS_NOTIFY | LBS_OWNERDRAWFIXED | LBS_HASSTRINGS | LBS_NOINTEGRALHEIGHT | WS_BORDER | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "Clear", IDC_CAPTURE_KEY_CLEAR, 7, 99, 50, 14
    DEFPUSHBUTTON "OK", 1, 109, 99, 50, 14
    PUSHBUTTON "Cancel", 2, 163, 99, 50, 14
END

IDD_CAPTURE_MOUSE DIALOGEX 0, 0, 220, 72
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Modify Shortcuts"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Click in the field below to record a binding. Wheel, double click and held modifiers are captured; right click is reserved.", -1, 7, 9, 206, 17
    CONTROL "", IDC_CAPTURE_MOUSE_FIELD, "RivMouseCapture", WS_TABSTOP | WS_BORDER, 7, 30, 206, 16
    PUSHBUTTON "Clear", IDC_CAPTURE_MOUSE_CLEAR, 7, 51, 50, 14
    DEFPUSHBUTTON "OK", 1, 109, 51, 50, 14
    PUSHBUTTON "Cancel", 2, 163, 51, 50, 14
END

IDD_ABOUT DIALOGEX 0, 0, 200, 100
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About"
FONT 9, "Segoe UI"
BEGIN
    CTEXT "riv", IDC_ABOUT_TITLE, 0, 4, 200, 38
    CTEXT "", IDC_ABOUT_VERSION, 0, 46, 200, 14
    CTEXT "Built with Rust (x86-64-v3)", -1, 0, 68, 200, 10
    CONTROL "Source code available under GPLv3 on <a href=""https://github.com/sohnyj/riv"">GitHub</a>", IDC_ABOUT_LINK, "SysLink", WS_TABSTOP, 0, 82, 200, 10
END
